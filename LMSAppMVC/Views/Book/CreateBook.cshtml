@model LMSAppMVC.Models.DTOs.AddBookRequestModel

@{
    ViewBag.Title = "Create Book";
    Layout = "";
}

<form asp-action="CreateBook" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-row">
        <div class="form-group col-sm-6">
            <label asp-for="Title" class="control-label"></label>
            <input asp-for="Title" required class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group col-sm-6">
            <label asp-for="Author" class="control-label"></label>
            <input asp-for="Author" required class="form-control" />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>
        <div class="form-group col-sm-6">
            <label asp-for="ISBN" class="control-label"></label>
            <input asp-for="ISBN" required class="form-control" />
            <span asp-validation-for="ISBN" class="text-danger"></span>
        </div>
        
        <div class="form-group col-sm-6">
            <label asp-for="ISBNYear" class="control-label"></label>
            <input asp-for="ISBNYear" required class="form-control" />
            <span asp-validation-for="ISBNYear" class="text-danger"></span>
        </div>

        @* <div class="form-group col-sm-6"> *@
        @*     <label asp-for="DateCreated" class="control-label"></label> *@
        @*     <input asp-for="DateCreated" class="form-control" /> *@
        @*     <span asp-validation-for="DateCreated" class="text-danger"></span> *@
        @* </div> *@


    </div>

    <div class="form-group ">
        <input href="#myModal" type="submit" value="Submit" class="btn btn-success trigger-btn col-sm-12" data-toggle="modal" />
    </div>

</form>