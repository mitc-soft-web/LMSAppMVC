
@{
    Layout = null;
}

@model LMSAppMVC.Models.DTOs.Auth.GenerateLibrarianRegistratationCodeRequestModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background-image: url('/images/library-bg.png');
        background-size: cover;
        background-position: center;
        height: 100vh;
    }

    .overlay {
        background: rgba(0, 0, 0, 0.55);
        height: 100vh;
    }

    .card-auth {
        width: 450px;
        border-radius: 16px;
        backdrop-filter: blur(10px);
    }

    .input-validation-error {
        border-color: #dc3545;
    }
</style>


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Send Registration Code </title>
    <link rel="stylesheet" href="~/styles/register.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">

</head>

<body>
<div class="overlay">

    <div class="container vh-100 d-flex justify-content-center align-items-center">

        <div class="card shadow-lg border-0 card-auth">

            <div class="card-body p-4">

                <div class="text-center mb-4">

                    <h3 class="fw-bold">Librarian Access</h3>

                    <p class="text-muted small">
                        Enter librarian email to receive registration code
                    </p>

                </div>


                    <form asp-action="SendInvitationCode" method="post">

                    <div class="form-floating mb-3">
                        <input type="email" asp-for="Email" class="form-control" placeholder="Email">
                        <label>Email</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                        <div class="form-floating mb-3">
                            <input type="text" asp-for="FullName" class="form-control" placeholder="Full Name">
                            <label>Full Name</label>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>


                    <button class="btn btn-dark w-100">

                        Send Code

                    </button>

                </form>



            </div>

        </div>

    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<script src="https://ajax.aspnetcdn.com/ajax/jquery/jquery-3.7.1.min.js"></script>
<script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://ajax.aspnetcdn.com/ajax/mvc/5.2.3/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>