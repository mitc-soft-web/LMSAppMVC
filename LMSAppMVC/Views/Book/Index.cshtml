@model IReadOnlyList<LMSAppMVC.Models.Book>

@{
    ViewBag.Title = "Books";
    Layout = "";
}

<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/html">

<!-- Bootstrap CSS -->
<link href="assets1/css/bootstrap.min.css" rel="stylesheet">
<!-- bootstrap theme -->
<link href="assets1/css/bootstrap-theme.css" rel="stylesheet">
<!--external css-->
<!-- font icon -->
<link href="assets1/css/elegant-icons-style.css" rel="stylesheet" />
<link href="assets1/css/font-awesome.min.css" rel="stylesheet" />
<!-- Custom styles -->
<link href="assets1/css/style.css" rel="stylesheet">
<link href="assets1/css/style-responsive.css" rel="stylesheet" />
@* *@
@* <div class="card-header" style="background-color:midnightblue;"> *@
@*     <div class="card-title"> *@
@*         <h1 class="text-center">Category</h1> *@
@*     </div> *@
@* </div> *@

<div class="row">
    <div class="col-lg-12">
        <h3 class="page-header"><i class="fa fa-table"></i> Books</h3>
    </div>
</div>


<body>
    @foreach (var book in Model)
    {
        <div class="row">
            <div class="col-lg-12">
                <section class="panel">
                    <header class="panel-heading">
                        Book Table
                    </header>

                    <table class="table table-striped table-advance table-hover">
                        <tbody>
                            <tr>
                                <th><i class="icon_profile"></i> ID</th>
                                <th><i class="icon_profile"></i> Title</th>
                                <th><i class="icon_calendar"></i> Author</th>
                                <th><i class="icon_profile"></i> ISBN</th>
                                <th><i class="icon_profile"></i> ISBN Year</th>
                                <th><i class="icon_cogs"></i> Action</th>
                            </tr>
                            <tr>
                                <td>@book.Id</td>
                                <td>@book.Title</td>
                                <td>@book.Author</td>
                                <td>@book.ISBN</td>
                                <td>@book.ISBNYear</td>
                                @* <td>
                                    <div class="btn-group">
                                        <a class="btn btn-primary" asp-action="EditDepartment" asp-route-id="@dept.Id"><i class="icon_plus_alt2"></i></a>
                                        <a class="btn btn-success" asp-action="GetDepartment" asp-route-id="@dept.Id"><i class="icon_check_alt2"></i></a>
                                        <a class="btn btn-danger" asp-action="DeleteDepartment" asp-route-id="@dept.Id"><i class="icon_close_alt2"></i></a>
                                    </div>
                                </td> *@
                            </tr>

                        </tbody>
                    </table>
                </section>
            </div>
        </div>
    }

    <!-- container section end -->
    <!-- javascripts -->
    <script src="assets1/js/jquery.js"></script>
    <script src="assets1/js/bootstrap.min.js"></script>
    <!-- nicescroll -->
    <script src="assets1/js/jquery.scrollTo.min.js"></script>
    <script src="assets1/js/jquery.nicescroll.js" type="text/javascript"></script>
    <!--custome script for all page-->
    <script src="assets1/js/scripts.js"></script>

</body>

</html>
<button style="background-color: midnightblue"><a asp-controller="Book" asp-action="CreateBook">Add Book</a> </button>

<button style="background-color: midnightblue"><a asp-controller="User" asp-action="StockKeeperIndex">Return to your Dashboard</a> </button>
