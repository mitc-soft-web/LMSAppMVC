@model LMSAppMVC.Models.DTOs.Book.AddBookRequestModel

@{
    Layout = null;
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background-image: url('/images/library-bg.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed; /* Added to keep bg stable when scrolling */
        min-height: 100vh;
    }

    /* Dark overlay */
    .overlay {
        background: rgba(0, 0, 0, 0.55);
        min-height: 100vh; /* Changed to min-height for mobile scrolling */
        display: flex;
        align-items: center;
        padding: 20px 0;
    }

    /* Card styling */
    .register-card {
        width: 100%; /* Responsive base */
        max-width: 500px; /* Your original size on desktop */
        border-radius: 16px;
        backdrop-filter: blur(10px);
    }

    .input-validation-error {
        border-color: #dc3545;
    }


    /* Modern minimalist styling */
    .modern-form {
        max-width: 400px;
        margin: 2rem auto;
        padding: 2rem;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #333;
    }

    .form-select {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #ddd;
        border-radius: 8px;
        background-color: #f9f9f9;
        transition: border-color 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }

        .form-select:focus {
            border-color: #007bff;
            outline: none;
            box-shadow: 0 0 0 3px rgba(0,123,255,0.1);
        }

    .btn-submit {
        width: 100%;
        padding: 0.8rem;
        background: #007bff;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
    }

    #preloader {
        display: none !important;
    }

</style>


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Author </title>
    <link rel="stylesheet" href="~/styles/register.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">

</head>

<body>

    <div class="overlay">

        <div class="container d-flex justify-content-center align-items-center">

            <div class="card shadow-lg border-0 register-card">

                <div class="card-body p-4">
                    @if (ViewBag.Message != null)
                    {
                        @* Removed position:fixed so it is responsive and visible inside the card *@
                        <div id="auto-close-alert" class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                            @ViewBag.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>

                        <script>
                            setTimeout(function() {
                                var alertElem = document.getElementById('auto-close-alert');
                                if (alertElem) {
                                    var bsAlert = new bootstrap.Alert(alertElem);
                                    bsAlert.close();
                                }
                            }, 5000);
                        </script>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="tab-content">

                        <!-- AUTHOR FORM -->
                        <div class="tab-pane fade show active" id="member">

                            <div class="text-center mb-4">

                                <h3 class="fw-bold">Add Book</h3>
                                <p class="text-muted small">
                                    Access your library account
                                </p>

                            </div>

                            <form method="post" asp-action="AddBook" asp-controller="Book">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                                <div class="form-floating mb-3">
                                    <input type="text" asp-for="Title" class="form-control" placeholder="Book Title">
                                    <label>Title</label>
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="AuthorId">Select Author</label>
                                    <select id="AuthorId" name="AuthorId"
                                            class="form-select"
                                            asp-items="ViewBag.Authors">
                                        <option value="">-- Choose Author --</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label asp-for="CategoryId">Select Category</label>
                                    <select id="CategoryId" name="CategoryId"
                                            class="form-select"
                                            asp-items="ViewBag.Categories">
                                        <option value="">-- Choose Category --</option>
                                    </select>
                                </div>



                                <div class="form-floating mb-3">
                                    <input type="number" asp-for="PublishedYear" class="form-control" placeholder="Published Year">
                                    <label>Year of Publication</label>
                                    <span asp-validation-for="PublishedYear" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="text" asp-for="ISBN" class="form-control" placeholder="ISBN">
                                    <label>ISBN</label>
                                    <span asp-validation-for="ISBN" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="number" asp-for="TotalCopies" class="form-control" placeholder="TotalCopies">
                                    <label>Total Copies</label>
                                    <span asp-validation-for="TotalCopies" class="text-danger small"></span>
                                </div>

                               

                                <button class="btn btn-primary w-100">
                                    Add Book
                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <script src="https://ajax.aspnetcdn.com/ajax/jquery/jquery-3.7.1.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/mvc/5.2.3/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
