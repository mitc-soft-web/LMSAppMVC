@{
    Layout = null;
}

@model LMSAppMVC.Models.DTOs.Auth.RegisterViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background-image: url('/images/library-bg.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed; /* Added to keep bg stable when scrolling */
        min-height: 100vh;
    }

    /* Dark overlay */
    .overlay {
        background: rgba(0, 0, 0, 0.55);
        min-height: 100vh; /* Changed to min-height for mobile scrolling */
        display: flex;
        align-items: center;
        padding: 20px 0;
    }

    /* Card styling */
    .register-card {
        width: 100%; /* Responsive base */
        max-width: 500px; /* Your original size on desktop */
        border-radius: 16px;
        backdrop-filter: blur(10px);
    }

    .input-validation-error {
        border-color: #dc3545;
    }
</style>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register </title>
    <link rel="stylesheet" href="~/styles/register.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">

</head>

<body>

    <div class="overlay">

        <div class="container d-flex justify-content-center align-items-center">

            <div class="card shadow-lg border-0 register-card">

                <div class="card-body p-4">
                    @if (ViewBag.Message != null)
                    {
                        @* Removed position:fixed so it is responsive and visible inside the card *@
                        <div id="auto-close-alert" class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                            @ViewBag.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>

                        <script>
                            setTimeout(function() {
                                var alertElem = document.getElementById('auto-close-alert');
                                if (alertElem) {
                                    var bsAlert = new bootstrap.Alert(alertElem);
                                    bsAlert.close();
                                }
                            }, 5000);
                        </script>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }



                    <h3 class="text-center fw-bold mb-4 text-dark">
                        Library Registration
                    </h3>

                    <!-- Tabs -->
                    <ul class="nav nav-pills nav-justified mb-4">

                        <li class="nav-item">
                            <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#member">
                                Member
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#librarian">
                                Librarian
                            </button>
                        </li>

                    </ul>


                    <div class="tab-content">

                        <!-- MEMBER FORM -->
                        <div class="tab-pane fade show active" id="member">

                            <form method="post" asp-action="RegisterMember" asp-controller="Auth">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                                <div class="form-floating mb-3">
                                    <input type="text" asp-for="Member.FullName" class="form-control" placeholder="Full Name"
                                           >
                                    <label>Full Name</label>
                                    <span asp-validation-for="Member.FullName" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="email" asp-for="Member.Email" class="form-control" placeholder="Email" >
                                    <label>Email</label>
                                    <span asp-validation-for="Member.Email" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="tel" asp-for="Member.PhoneNumber" class="form-control" placeholder="Phone Number" >
                                    <label>Phone Number</label>
                                    <span asp-validation-for="Member.PhoneNumber" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="text" asp-for="Member.Address" class="form-control" placeholder="Address">
                                    <label>Address</label>
                                    <span asp-validation-for="Member.Address" class="text-danger small"></span>
                                </div>

                                <!-- Inside the Member Tab (Password Field) -->
                                <div class="mb-3">
                                    <div class="form-floating position-relative">
                                        <input type="password" asp-for="Member.HashPassword" class="form-control pe-5" id="memPasswordInput" placeholder="Password">
                                        <label>Password</label>
                                        <span class="position-absolute top-50 end-0 translate-middle-y me-3"
                                              style="cursor: pointer; z-index: 10;"
                                              onclick="togglePassword('memPasswordInput', this)">
                                            <i class="bi bi-eye-slash text-secondary"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="Member.HashPassword" class="text-danger small"></span>
                                </div>

                                <!-- Member Confirm Password -->
                                <div class="mb-3">
                                    <div class="form-floating position-relative">
                                        @* Unique ID: confInput *@
                                        <input type="password" asp-for="Member.ConfirmPassword" class="form-control pe-5" id="memConfInput" placeholder="Confirm Password">
                                        <label asp-for="Member.ConfirmPassword">Confirm Password</label>

                                        <span class="position-absolute top-50 end-0 translate-middle-y me-3"
                                              style="cursor: pointer; z-index: 10;"
                                              onclick="togglePassword('memConfInput', this)">
                                            <i class="bi bi-eye-slash"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="Member.ConfirmPassword" class="text-danger small"></span>
                                </div>


                                <button class="btn btn-primary w-100">
                                    Register as Member
                                </button>

                            </form>

                        </div>


                        <!-- LIBRARIAN FORM -->
                        <div class="tab-pane fade" id="librarian">

                            <form method="post" asp-action="RegisterLibrarian" asp-controller="Auth">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                                <div class="form-floating mb-3">
                                    @* FIXED: Changed Member.FullName to Librarian.FullName *@
                                    <input type="text" asp-for="Librarian.FullName" class="form-control" placeholder="Full Name">
                                    <label>Full Name</label>
                                    <span asp-validation-for="Librarian.FullName" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="email" asp-for="Librarian.Email" class="form-control" placeholder="Email">
                                    <label>Email</label>
                                    <span asp-validation-for="Librarian.Email" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="text" asp-for="Librarian.LibrarianRegistrationCode" class="form-control"
                                           placeholder="Registration Code">
                                    <label>Registration Code</label>
                                    <span asp-validation-for="Librarian.LibrarianRegistrationCode" class="text-danger small"></span>
                                </div>

                                <!-- Librarian Password -->
                                <div class="mb-3">
                                    <div class="form-floating position-relative">
                                        @* Notice the unique ID: libPasswordInput *@
                                        <input type="password" asp-for="Librarian.HashPassword" class="form-control pe-5" id="libPasswordInput" placeholder="Password">
                                        <label>Password</label>
                                        <span class="position-absolute top-50 end-0 translate-middle-y me-3"
                                              style="cursor: pointer; z-index: 10;"
                                              onclick="togglePassword('libPasswordInput', this)">
                                            <i class="bi bi-eye-slash text-secondary"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="Librarian.HashPassword" class="text-danger small"></span>
                                </div>

                                <!-- Librarian Confirm Password -->
                                <div class="mb-3">
                                    <div class="form-floating position-relative">
                                        @* Unique ID: confInput *@
                                        <input type="password" asp-for="Librarian.ConfirmPassword" class="form-control pe-5" id="libConfInput" placeholder="Confirm Password">
                                        <label asp-for="Librarian.ConfirmPassword">Confirm Password</label>

                                        <span class="position-absolute top-50 end-0 translate-middle-y me-3"
                                              style="cursor: pointer; z-index: 10;"
                                              onclick="togglePassword('libConfInput', this)">
                                            <i class="bi bi-eye-slash"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="Librarian.ConfirmPassword" class="text-danger small"></span>
                                </div>


                                <button class="btn btn-dark w-100">
                                    Register as Librarian
                                </button>

                            </form>

                        </div>

                        <hr>

                        <div class="text-center small">

                            Already have an account?
                            <a asp-action="Login" class="fw-semibold text-decoration-none">
                                Login
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <script src="https://ajax.aspnetcdn.com/ajax/jquery/jquery-3.7.1.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/mvc/5.2.3/jquery.validate.unobtrusive.min.js"></script>

    <script>
        function togglePassword(inputId, el) {
            const passwordInput = document.getElementById(inputId);
            const icon = el.querySelector('i');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.replace('bi-eye-slash','bi-eye');
            } else {
                passwordInput.type = 'password';
                icon.classList.replace('bi-eye','bi-eye-slash');
            }
        }
    </script>
</body>
</html>


